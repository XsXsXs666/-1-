-- 执行范围修改
local currentConnection = nil

local function applyRange(rangeValue)
    -- 断开之前的连接
    if currentConnection then
        currentConnection:Disconnect()
    end
    
    -- 启动新的循环
    currentConnection = RunService.RenderStepped:Connect(function()
        local npcs = findAllNPCs()
        
        for _, npc in ipairs(npcs) do
            -- 查找NPC的HumanoidRootPart或主要部件
            local rootPart = npc:FindFirstChild("HumanoidRootPart")
            
            -- 如果没有HumanoidRootPart，尝试找Humanoid然后找RootPart
            if not rootPart then
                local humanoid = npc:FindFirstChild("Humanoid")
                if humanoid and humanoid.RootPart then
                    rootPart = humanoid.RootPart
                end
            end
            
            -- 如果还没有，尝试找名称包含"Torso"或"UpperTorso"的部件
            if not rootPart then
                for _, part in ipairs(npc:GetChildren()) do
                    if part:IsA("BasePart") and (string.find(part.Name, "Torso") or string.find(part.Name, "Root")) then
                        rootPart = part
                        break
                    end
                end
            end
            
            -- 修改找到的部件
            if rootPart and rootPart:IsA("BasePart") then
                rootPart.Size = Vector3.new(rangeValue, rangeValue, rangeValue)
                rootPart.Transparency = CONFIG.Transparency
                rootPart.Color = Color3.fromRGB(CONFIG.Red, CONFIG.Green, CONFIG.Blue)
                rootPart.Material = CONFIG.Material
                rootPart.CanCollide = false
            end
        end
    end)
end

